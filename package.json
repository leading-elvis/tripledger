{
  "name": "tripledger",
  "version": "1.0.0",
  "private": true,
  "description": "團體旅遊分帳系統 - 跨平台應用",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "api:start": "npm run start:prod --workspace=apps/api",
    "api:test": "npm run test --workspace=apps/api",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "pg": "^8.18.0"
  }
}
