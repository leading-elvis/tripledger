# ==================================
# TripLedger 生產環境配置範例
# ==================================
# 請複製此檔案並填入實際值
# 注意：不要將實際的 .env.production 提交到 Git

# ==================================
# Cloud SQL 連線 (Cloud Run 使用 Unix Socket)
# ==================================
# 格式: postgresql://USER:PASSWORD@localhost/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://tripledger_user:YOUR_PASSWORD@localhost/tripledger?host=/cloudsql/tripledger-484503:asia-east1:tripledger-db"

# ==================================
# JWT 配置 (請使用強隨機字串)
# ==================================
# 產生方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-production-jwt-secret-at-least-64-characters-long"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-production-refresh-secret-different-from-jwt-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ==================================
# LINE Login (從 LINE Developers Console 取得)
# ==================================
# https://developers.line.biz/console/
LINE_CHANNEL_ID="your-line-channel-id"
LINE_CHANNEL_SECRET="your-line-channel-secret"
LINE_CALLBACK_URL="https://tripledger-api-297896850903.asia-east1.run.app/api/auth/line/callback"

# ==================================
# Google OAuth (從 Google Cloud Console 取得)
# ==================================
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://tripledger-api-297896850903.asia-east1.run.app/api/auth/google/callback"

# ==================================
# 應用程式配置
# ==================================
PORT=8080
NODE_ENV="production"
# 允許的 CORS 來源，多個用逗號分隔
# 允許的 CORS 來源，多個用逗號分隔（Flutter App 不需要 CORS）
CORS_ORIGIN="*"

# ==================================
# (選擇性) LINE Bot
# ==================================
LINE_BOT_CHANNEL_ACCESS_TOKEN=""
LINE_BOT_CHANNEL_SECRET=""

# ==================================
# (選擇性) Discord Bot
# ==================================
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ==================================
# (選擇性) Cloud Storage (收據圖片)
# ==================================
# 如果使用 GCS，需要額外配置
GCS_BUCKET_NAME=""

# ==================================
# Firebase Cloud Messaging (推播通知)
# ==================================
# 從 Firebase Console > 專案設定 > 服務帳戶 取得
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# 注意：私鑰需要保持換行格式
FIREBASE_PRIVATE_KEY=""

# ==================================
# AI / OCR 服務
# ==================================
# Anthropic API (品牌 AI 建議) - https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Google Cloud Vision API (收據 OCR)
# 在 Cloud Run 上建議使用 Workload Identity，或設定服務帳號
GOOGLE_CLOUD_VISION_API_KEY=""

# ==================================
# 匯率服務
# ==================================
# Exchange Rate API - https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=""

# ==================================
# 內購 (In-App Purchase)
# ==================================
# Apple App Store
APPLE_BUNDLE_ID="com.leadinginstr.tripledger"
APPSTORE_ISSUER_ID=""
APPSTORE_KEY_ID=""
# 注意：私鑰需要保持換行格式
APPSTORE_PRIVATE_KEY=""

# Google Play
GOOGLE_PACKAGE_NAME="com.tripledger.tripledger"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# ==================================
# Apple 審核用 Demo 登入
# ==================================
# 警告：審核完成後請立即關閉！
# 設為 "ENABLED_FOR_APPLE_REVIEW" 啟用
ALLOW_DEMO_LOGIN_FOR_APP_REVIEW=""
DEMO_USERNAME=""
DEMO_PASSWORD=""
