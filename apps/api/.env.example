# 資料庫
DATABASE_URL="postgresql://user:password@localhost:5432/tripledger?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# LINE Login
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_CALLBACK_URL="http://localhost:3000/api/auth/line/callback"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# LINE Bot
LINE_BOT_CHANNEL_ACCESS_TOKEN=""
LINE_BOT_CHANNEL_SECRET=""

# Discord Bot
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# AWS S3
AWS_REGION="ap-northeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# Firebase (FCM)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ===========================================
# AI / OCR 服務
# ===========================================

# Anthropic API (品牌 AI 建議)
ANTHROPIC_API_KEY=""

# Google Cloud Vision API (收據圖片 OCR)
# 方式一：使用 API Key（較簡單）
GOOGLE_CLOUD_VISION_API_KEY=""

# 方式二：使用服務帳號（較安全，推薦用於生產環境）
# 在 Cloud Run 上可使用 Workload Identity，無需設定這些變數
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_CLIENT_EMAIL=""
# 注意：私鑰需要保持換行格式，可使用 \n
GOOGLE_CLOUD_PRIVATE_KEY=""

# App
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:8080"

# ===========================================
# 匯率服務
# ===========================================
# Exchange Rate API Key (https://www.exchangerate-api.com/)
# 免費方案每月 1500 次請求
EXCHANGE_RATE_API_KEY=""

# ===========================================
# 開發/審核用設定（生產環境請謹慎使用）
# ===========================================
# 設為 true 可在開發環境跳過內購收據驗證（僅當 NODE_ENV=development 時有效）
SKIP_RECEIPT_VERIFICATION=""

# Demo 登入（供 Apple 審核使用）
# 注意：審核完成後請立即關閉，避免安全風險
# 設為 "ENABLED_FOR_APPLE_REVIEW" 啟用 Demo 登入
ALLOW_DEMO_LOGIN_FOR_APP_REVIEW=""
# Demo 帳號密碼（請使用強密碼，審核完成後請更換或刪除）
DEMO_USERNAME=""
DEMO_PASSWORD=""

# ===========================================
# 內購 (In-App Purchase) 設定
# ===========================================

# Apple App Store
# - Bundle ID 需要與 App Store Connect 上的 App 一致
APPLE_BUNDLE_ID="com.leadinginstr.tripledger"
# - Shared Secret: App Store Connect > App > App 內購買項目 > App 專用共享密鑰
# - 非訂閱型產品可選，訂閱型產品必填
APPLE_SHARED_SECRET=""
# - 從 App Store Connect > 用戶與存取權限 > 密鑰 取得 (用於 StoreKit 2 / App Store Server API)
APPSTORE_ISSUER_ID=""
APPSTORE_KEY_ID=""
# 注意：私鑰需要保持換行格式，可使用 \n 或多行字串
APPSTORE_PRIVATE_KEY=""

# Google Play
# - 從 Google Cloud Console 建立 Service Account 並下載 JSON 金鑰
# - 在 Google Play Console 授予此 Service Account 財務權限
GOOGLE_PACKAGE_NAME="com.tripledger.tripledger"
# 方式一：直接貼上整個 JSON（較方便但較長）
GOOGLE_SERVICE_ACCOUNT_JSON=""
# 方式二：分開設定（較易閱讀）
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
